<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/browseEventsTopContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/secondaryBackground"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/browseEventsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/secondaryBackground"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Browse Events"
                android:textSize="22sp"
                android:gravity="start"
                android:layout_weight="1"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                android:clickable="true"
                android:focusable="true"
                android:backgroundTint="@color/primaryBackground">

                <ImageView
                    android:id="@+id/searchButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/placeholder_image" />
            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/spinnersBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="2"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <Spinner
                android:id="@+id/browseEventsInterestsSpinner"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:entries="@array/browse_events_interests_spinner"
                android:spinnerMode="dropdown"
                android:background="@color/secondaryClickableCardsAndSpinners"
                android:padding="6dp"
                android:layout_marginEnd="12dp" />

            <Spinner
                android:id="@+id/browseEventsAvailabilitySpinner"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:entries="@array/browse_events_availability_spinner"
                android:spinnerMode="dropdown"
                android:background="@color/secondaryClickableCardsAndSpinners"
                android:padding="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/eventsHeaderRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/browseEventsTopContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="parent">

        <TextView
            android:id="@+id/upcomingText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/headerSubtext"
            android:gravity="start"/>

        <TextView
            android:id="@+id/resultsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/headerSubtext"
            android:gravity="end"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/eventsHeaderRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/eventsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false">

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>